# CertVault backend — copy to .env and fill in
PORT=3001

# Supabase (required for CertVault)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudinary (for PDF certificate hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Certificate PDF generator service (Flask app; can run separately)
CERTGEN_SERVICE_URL=http://localhost:5050

# CORS — comma-separated origins allowed to call the API
ALLOWED_ORIGINS=https://certvault.example.com,http://localhost:5174

# Public URL of the app (e.g. https://your-app.up.railway.app). When set, this origin is allowed for CORS.
PUBLIC_URL=
