# CertVault backend — copy to .env and fill in
# Required: CONVEX_URL (run `npx convex dev` to create a project and get the URL)
# On Railway: set CONVEX_URL in the service Variables tab (see RAILWAY.md)
PORT=3001

# Convex (required for CertVault)
CONVEX_URL=https://your-deployment.convex.cloud

# Cloudinary (for PDF certificate hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Or use a single URL instead of the 3 values above:
# CLOUDINARY_URL=cloudinary://<your_api_key>:<your_api_secret>@<your_cloud_name>

# Certificate PDF generator service (Flask app; can run separately)
CERTGEN_SERVICE_URL=http://localhost:5050

# CORS — comma-separated origins allowed to call the API
ALLOWED_ORIGINS=https://certvault.example.com,http://localhost:5174

# Public URL of the app (e.g. https://your-app.up.railway.app). When set, this origin is allowed for CORS.
PUBLIC_URL=
